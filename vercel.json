{
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "functions": {
    "api/prerender.ts": {
      "memory": 256,
      "maxDuration": 15,
      "includeFiles": "out/**"
    }
  },
  "routes": [
    {
      "src": "/(arriendo|venta|renta-corta|arriendo-tradicional|arriendo-renta-corta)/(.*)",
      "dest": "/api/prerender"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}