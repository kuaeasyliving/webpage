{
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "functions": {
    "api/prerender.ts": {
      "memory": 256,
      "maxDuration": 15,
      "includeFiles": "out/index.html"
    }
  },
  "routes": [
    { "src": "/arriendo/(.*)", "dest": "/api/prerender" },
    { "src": "/venta/(.*)", "dest": "/api/prerender" },
    { "src": "/renta-corta/(.*)", "dest": "/api/prerender" },
    { "src": "/arriendo-tradicional/(.*)", "dest": "/api/prerender" },
    { "src": "/arriendo-renta-corta/(.*)", "dest": "/api/prerender" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}